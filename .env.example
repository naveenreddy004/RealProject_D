BASE_URL=https://yourdomain.com
PORT=3000
NODE_ENV=production

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Use MongoDB Atlas URI (recommended) OR local mongo from docker-compose
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/certifypro

# ─── Email (Gmail App Password) ───────────────────────────────────────────────
EMAIL_USER=yourmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_32_char_string
JWT_EXPIRES_IN=7d

# ─── UPI Payment ──────────────────────────────────────────────────────────────
UPI_ID=yourphonenumber@ybl
UPI_NAME=Your Company Name
UPI_AMOUNT=199

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_KEY=your_secret_admin_key
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=StrongPassword@123

# ─── App ──────────────────────────────────────────────────────────────────────
SUPPORT_EMAIL=support.avrontech@gmail.com
CERT_VALIDITY_YEARS=2

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set to your actual domain in production, never use * in prod
ALLOWED_ORIGINS=https://yourdomain.com
