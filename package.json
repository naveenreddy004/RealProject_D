{
  "name": "avron-tech-platform",
  "version": "3.0.0",
  "description": "avRoN Tech — Full Stack Internship Platform with interactive course dashboard, LeetCode assignments, attendance tracking, and certificate management",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed:course": "node scripts/seeds/seedCourseContent.js",
    "seed:assignments": "node scripts/seeds/seedAssignments.js",
    "seed:all": "node scripts/seeds/seedCourseContent.js && node scripts/seeds/seedAssignments.js",
    "seed:test-student": "node scripts/seeds/seedCompleteBundle.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.14.0",
    "qrcode": "^1.5.3",
    "razorpay": "^2.9.6",
    "uuid": "^9.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
